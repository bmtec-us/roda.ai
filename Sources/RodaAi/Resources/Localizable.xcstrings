    "voice.system.prompt" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are in RodaAi's voice mode.\nReply in the same language as the user, in a natural spoken style.\nUse short, clear sentences with speech rhythm.\nAvoid complex markdown, code blocks, and long lists.\nUse at most one short bold emphasis when needed."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voce esta no modo de voz do RodaAi.\nResponda no mesmo idioma do usuario, de forma natural e falada.\nFale em frases curtas e claras, com ritmo de fala.\nEvite markdown complexo, codigo e listas longas.\nSe precisar enfatizar, use no maximo um destaque curto em negrito."
          }
        }
      }
    },
    "Voz neural multilingua opcional — use Ajustes para ativar" : {
      "comment" : "A description of the neural voice model.",
      "extractionState" : "stale",
